{
  "name": "playlet-ai-manga",
  "version": "1.0.6",
  "private": true,
  "type": "module",
  "description": "AI影视自动化生成系统 - 基于Nuxt.js 4 + Google Gemini API",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "media:migrate:tos": "node scripts/migrate-local-media-to-tos.mjs",
    "media:migrate:video-task-config": "bun run scripts/migrate-video-task-config-to-cloud.ts",
    "release": "bun run scripts/release.ts"
  },
  "dependencies": {
    "@google/genai": "^1.32.0",
    "@pinia/nuxt": "^0.11.3",
    "@tiptap/extension-placeholder": "^3.14.0",
    "@tiptap/starter-kit": "^3.14.0",
    "@tiptap/vue-3": "^3.14.0",
    "@volcengine/tos-sdk": "^2.9.1",
    "@vueuse/core": "^14.2.1",
    "better-sqlite3": "^12.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx": "^9.6.1",
    "drizzle-orm": "^0.45.0",
    "fluent-ffmpeg": "^2.1.3",
    "lucide-vue-next": "^0.511.0",
    "nuxt": "^4.2.1",
    "openai": "^6.33.0",
    "pinia": "^3.0.4",
    "radix-vue": "^1.9.17",
    "reka-ui": "^2.9.6",
    "sharp": "^0.33.5",
    "tailwind-merge": "^3.1.0",
    "three": "^0.184.0",
    "vaul-vue": "^0.4.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.10.0",
    "@nuxt/test-utils": "^3.21.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/three": "^0.184.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@vue/test-utils": "^2.4.6",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.1",
    "shadcn-nuxt": "^2.4.2",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9",
    "vue-tsc": "^3.1.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "bun@1.2.15"
}
