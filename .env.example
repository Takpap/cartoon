# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# 阿里云千问 API (DashScope)
# 获取地址: https://bailian.console.aliyun.com/?tab=model#/api-key
QWEN_API_KEY=your_qwen_api_key_here

# 火山引擎 API (方舟平台)
# 获取地址: https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
VOLCENGINE_API_KEY=your_volcengine_api_key_here

# 可选：代理配置（国内访问 Gemini 需要）
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# 输出配置
OUTPUT_DIR=./output
TEMP_DIR=./temp

# 视频默认参数
DEFAULT_RESOLUTION=1080p
DEFAULT_ASPECT_RATIO=16:9
DEFAULT_DURATION=8

# 并发控制
MAX_CONCURRENT_REQUESTS=3

# 日志级别
LOG_LEVEL=info

# FFmpeg 路径（可选，仅当 FFmpeg 不在系统 PATH 中时需要配置）
# Windows 示例: FFMPEG_PATH=C:\ProgramData\chocolatey\bin\ffmpeg.exe
# Mac/Linux 通常不需要配置，brew/apt 安装会自动加入 PATH
# FFMPEG_PATH=
# FFPROBE_PATH=

# 成本控制（单位：美元）
DAILY_BUDGET_LIMIT=50
