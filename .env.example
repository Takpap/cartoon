# Google Gemini API
# 支持多个 Key（逗号、分号或换行分隔），会自动轮询并在失效时切换
GEMINI_API_KEY=your_gemini_api_key_1,your_gemini_api_key_2

# 阿里云千问 API (DashScope)
# 获取地址: https://bailian.console.aliyun.com/?tab=model#/api-key
QWEN_API_KEY=your_qwen_api_key_here

# DeepSeek 官方 API (OpenAI 兼容)
# 获取地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 可灵 AI API
# 获取地址: https://klingai.com/dev/api-key
KLING_ACCESS_KEY=your_kling_access_key_here
KLING_SECRET_KEY=your_kling_secret_key_here
# 可选：默认中国区域北京节点
KLING_BASE_URL=https://api-beijing.klingai.com

# 火山引擎 API (方舟平台)
# 获取地址: https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
VOLCENGINE_API_KEY=your_volcengine_api_key_here

# 火山云对象存储 TOS（可选，启用后图片/视频优先上传云端）
# 文档: https://www.volcengine.com/docs/6349/113482
# TOS_ENABLED=true
# TOS_ACCESS_KEY=your_tos_access_key
# TOS_SECRET_KEY=your_tos_secret_key
# TOS_REGION=cn-beijing
# TOS_ENDPOINT=tos-cn-beijing.volces.com
# TOS_BUCKET=your_bucket_name
# TOS_KEY_PREFIX=playlet-assets
# TOS_PUBLIC_BASE_URL=https://your-cdn-domain.com
# TOS_IS_CUSTOM_DOMAIN=false
# 可选：仅在确实需要时为 TOS 单独指定 HTTP 代理（默认直连，不读取 HTTP_PROXY/HTTPS_PROXY）
# TOS_PROXY=http://127.0.0.1:7890

# 可选：代理配置（国内访问 Gemini 需要）
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# 输出配置
OUTPUT_DIR=./output
TEMP_DIR=./temp

# 视频默认参数
DEFAULT_RESOLUTION=1080p
DEFAULT_ASPECT_RATIO=16:9
DEFAULT_DURATION=8

# 并发控制
MAX_CONCURRENT_REQUESTS=3

# 日志级别
LOG_LEVEL=info

# FFmpeg 路径（可选，仅当 FFmpeg 不在系统 PATH 中时需要配置）
# Windows 示例: FFMPEG_PATH=C:\ProgramData\chocolatey\bin\ffmpeg.exe
# Mac/Linux 通常不需要配置，brew/apt 安装会自动加入 PATH
# FFMPEG_PATH=
# FFPROBE_PATH=

# 成本控制（单位：美元）
DAILY_BUDGET_LIMIT=50
